# =====================================================================
# AI Cybersecurity Threat Intelligence & SOC Automation Platform env
# Copy this file to '.env' and fill in your keys before deployment.
# =====================================================================

# 1. Database Connection URL (Postgres container link)
# SQLite fallback: sqlite:///./threat_intel.db
DATABASE_URL=postgresql://postgres:postgrespassword@db:5432/threatintel

# 2. JWT Security Key (Generate a random high-entropy hex string)
# Example: openssl rand -hex 32
SECRET_KEY=supersecretkey_change_me_in_production_1234567890

# 3. Google Gemini 2.5 Flash API Key
# Required for RAG Chat Assistant and AI report generation
GEMINI_API_KEY=your_gemini_api_key_here

# 4. National Vulnerability Database API Key (Optional)
# Reduces NVD rate limit blocking during synchronization runs
NVD_API_KEY=

# 5. Threat Enrichment Feed Keys (Optional, falls back to rich mock profiles)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=

# 6. Logging Configuration
LOG_LEVEL=INFO
